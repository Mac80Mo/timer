{
  "name": "timer",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop timer for Linux, macOS, and Windows.",
  "main": "dist/electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:main dev:renderer dev:electron",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 file:dist/electron/main/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start": "electron .",
    "build": "npm-run-all build:main build:renderer",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "package": "npm run build && electron-builder",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "electron": "^37.0.0",
    "electron-builder": "^25.1.8",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.mac80mo.timer",
    "productName": "Desktop Timer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
